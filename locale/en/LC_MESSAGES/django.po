msgid "Botones"
msgstr "Buttons"

#: enjambre/templates/enjambre/mesa.html:335
msgid "Sillas de la mesa (quién participa)."
msgstr "Table seats (who participates)."

#: enjambre/templates/enjambre/mesa.html:336
