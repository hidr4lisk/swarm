msgstr "Download the chat as a .txt."

#: enjambre/templates/enjambre/mesa.html:337
msgid "Carpeta de la mesa: ver/descargar archivos y copiar la ruta en el host."
msgstr "Table folder: view/download files and copy the host path."

#: enjambre/templates/enjambre/mesa.html:338
msgid "Flujo de trabajo en vivo (qué hace cada silla, diffs)."
msgstr "Live workflow (what each seat is doing, diffs)."

#: enjambre/templates/enjambre/mesa.html:339
msgid "Esta ayuda."
msgstr "This help."

#: enjambre/templates/enjambre/mesa.html:343
msgid "<strong>Plana</strong> — todas las sillas responden al pedido."
msgstr "<strong>Flat</strong> — every seat replies to the request."

#: enjambre/templates/enjambre/mesa.html:344
msgid ""
"<strong>Líder</strong> (👑) — una silla coordina: descompone tu pedido en "
"subtareas, se\n"
"                    las reparte a las demás, y al final integra y reporta."
msgstr "<strong>Leader</strong> (👑) — one seat coordinates: it breaks your request into subtasks, hands them out to the rest, and finally integrates and reports."

#: enjambre/templates/enjambre/mesa.html:345
msgid "Se elige en <i class=\"fas fa-gear\"></i> Sillas de la mesa."
msgstr "Chosen in <i class=\"fas fa-gear\"></i> Table seats."

#: enjambre/templates/enjambre/mesa.html:347
msgid "Mensajes"
msgstr "Messages"

#: enjambre/templates/enjambre/mesa.html:348
msgid ""
"<code>@silla</code> — dirigir el turno a una sola silla (también saltea al "
"líder)."
msgstr "<code>@seat</code> — address the turn to a single seat (it also bypasses the leader)."

#: enjambre/templates/enjambre/mesa.html:350
msgid "(solo control)"
msgstr "(control only)"

#: enjambre/templates/enjambre/mesa.html:352
msgid ""
"<code>/armar &lt;qué&gt;</code> — las sillas construyen/editan en la carpeta "
"de la mesa y te muestran el diff."
msgstr "<code>/armar &lt;what&gt;</code> — the seats build/edit in the table’s folder and show you the diff."

#: enjambre/templates/enjambre/mesa.html:353
msgid "<code>/deshacer</code> — revierte el último <code>/armar</code>."
msgstr "<code>/deshacer</code> — reverts the last <code>/armar</code>."

#: enjambre/templates/enjambre/mesa.html:354
msgid ""
"<code>/volver &lt;sha&gt;</code> — rebobina la carpeta a ese commit "
"(granular); sin sha lista los commits."
msgstr "<code>/volver &lt;sha&gt;</code> — rewinds the folder to that commit (granular); without a sha it lists the commits."

#: enjambre/templates/enjambre/mesa.html:355
msgid ""
"<code>/debate &lt;tema&gt;</code> — las sillas discuten en rondas antes de "
"responder."
msgstr "<code>/debate &lt;topic&gt;</code> — the seats argue in rounds before answering."

#: enjambre/templates/enjambre/mesa.html:356
msgid ""
"<code>/alto</code> — corta el turno en curso (la silla que está corriendo "
"termina; el resto se saltea) y apaga el modo continuo."
msgstr "<code>/alto</code> — cuts the turn in progress (the seat that is running finishes; the rest are skipped) and turns off continuous mode."

#: enjambre/templates/enjambre/mesa.html:357
msgid ""
"<code>/continuo &lt;objetivo&gt;</code> — fija un objetivo y la mesa lo "
"construye iteración por iteración; corre una y frena."
msgstr "<code>/continuo &lt;goal&gt;</code> — sets a goal and the table builds it iteration by iteration; it runs one and stops."

#: enjambre/templates/enjambre/mesa.html:358
msgid ""
"<code>/seguí</code> — corre la próxima iteración hacia el objetivo continuo "
"(construye sobre lo ya hecho)."
msgstr "<code>/seguí</code> — runs the next iteration toward the continuous goal (it builds on top of what is done)."

#: enjambre/templates/enjambre/mesa.html:359
msgid ""
"<code>/continuo --auto &lt;obj&gt;</code> / <code>/auto</code> — modo "
"automático: el worker itera solo hasta el tope de costo, el máximo de "
"iteraciones, o <code>/alto</code>."
msgstr "<code>/continuo --auto &lt;goal&gt;</code> / <code>/auto</code> — automatic mode: the worker iterates on its own until the spend cap, the max iterations, or <code>/alto</code>."

#: enjambre/templates/enjambre/mesa.html:360
msgid ""
"<code>/cerrar</code> — cierra la mesa con un resumen (qué se construyó, "
"commits, costo total). No borra nada; bajás el resultado con 📁."
msgstr "<code>/cerrar</code> — closes the table with a summary (what was built, commits, total cost). Deletes nothing; grab the result with 📁."

#: enjambre/templates/enjambre/mesa.html:362
msgid "Se combinan: <code>@claude /armar …</code>"
msgstr "They combine: <code>@claude /armar …</code>"

#: enjambre/templates/enjambre/mesa.html:364
msgid ""
"Tu rango es <strong>consulta</strong>: charlás con las sillas. Los comandos "
"de construcción son del dueño."
msgstr "Your rank is <strong>consulta</strong> (view-only): you chat with the seats. Build commands belong to the owner."

