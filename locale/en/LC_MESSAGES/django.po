#: enjambre/templates/enjambre/mesa.html:247
msgid "Flujo de trabajo"
msgstr "Workflow"

#: enjambre/templates/enjambre/mesa.html:175
msgid "La mesa está en silencio. Hacé la primera pregunta."
msgstr "The table is silent. Ask the first question."

#: enjambre/templates/enjambre/mesa.html:183
msgid "El líder coordina al resto; @silla habla directo a una"
msgstr "The leader coordinates the rest; @seat talks straight to one"

#: enjambre/templates/enjambre/mesa.html:189
msgid ""
"Gasto estimado por silla (notional, a precio de lista — no es la factura "
"real)"
msgstr "Estimated spend per seat (notional, at list price — not the real bill)"

#: enjambre/templates/enjambre/mesa.html:192
