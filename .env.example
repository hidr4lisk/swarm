# Hidr4lisk_Swarm — copiá este archivo a `.env` y ajustá lo que necesites.
# Todos los valores tienen default razonable: para desarrollo local podés no setear nada.

# ── Django ──────────────────────────────────────────────────────────────────────
# SWARM_SECRET_KEY=cambiame-si-exponés-esto-fuera-de-tu-máquina
# SWARM_DEBUG=1
# SWARM_ALLOWED_HOSTS=localhost,127.0.0.1
# SWARM_TZ=America/Argentina/Buenos_Aires

# Base de datos. Sin setear = SQLite local. El docker-compose setea postgres.
# DATABASE_URL=postgres://swarm:swarm@db:5432/swarm

# ── Enjambre — motor de la mesa ─────────────────────────────────────────────────
# Wrapper de dispatch: runner Docker descartable. Vacío = CLIs directo en PATH.
# ENJAMBRE_RUNNER=./runner/enjambre-run.sh

# Carpetas de trabajo persistentes por mesa (vacío = ~/.enjambre/mesas).
# ENJAMBRE_MESAS_DIR=

# Git worktrees aislados de las Tareas (vacío = ~/.enjambre/workspaces).
# ENJAMBRE_WORKSPACES_DIR=

# Cómo te llaman las sillas en la mesa (queda como emisor de tus mensajes). Vacío = "Humano".
# ENJAMBRE_TITULO_HUMANO=

# ── Credenciales de tus CLIs (Linux-only; ver README, § modelo de amenaza) ─────
# Rutas en TU host a los archivos de credenciales que el compose monta RO solo en
# el runner. La app jamás pide ni guarda credenciales propias.
# SWARM_CLAUDE_CREDS=~/.claude/.credentials.json
# SWARM_OPENCODE_CREDS=~/.local/share/opencode/auth.json
# SWARM_AGY_CREDS=~/.gemini/antigravity-cli

# Config de opencode (OPCIONAL): si tus sillas opencode sin modelo fijo deben usar TU
# default (y tus proveedores custom), montá tu config. Vacío = el opencode del
# contenedor usa su propio default.
# SWARM_OPENCODE_CONFIG=~/.config/opencode/opencode.json

# Binarios de los CLIs en TU host, montados RO en el runner (defaults razonables).
# SWARM_CLAUDE_BIN=~/.local/bin/claude
# SWARM_OPENCODE_BIN=~/.opencode/bin/opencode
# SWARM_AGY_BIN=~/.local/bin/agy

# Carpeta de datos de Swarm (mesas, workspaces, conexiones.json). Default: ~/.enjambre
# SWARM_DATA_DIR=
